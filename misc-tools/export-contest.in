#!/usr/bin/env python3

'''
export-contest -- Convenience script to export a contest (including metadata,
teams and problems) from the command line. Defaults to using the CLI interface;
Specify a DOMjudge API URL as to use that.

Reads credentials from ~/.netrc when using the API.

Part of the DOMjudge Programming Contest Jury System and licensed
under the GNU GPL. See README and COPYING for details.
'''

import json
import sys
from concurrent.futures import ThreadPoolExecutor
from pathlib import Path

sys.path.append('@domserver_libdir@')
import dj_utils

cid = None
webappdir = '@domserver_webappdir@'


def usage():
    print(f'Usage: {sys.argv[0]} <contest-id> [<domjudge-api-url>]')
    exit(1)


def api_to_file(endpoint: str, filename: str):
    print(f"Fetching '{endpoint}' to '{filename}'")
    try:
        data = dj_utils.do_api_request(endpoint, decode=False)
        with open(filename, 'wb') as f:
            f.write(data)
        return data
    except Exception as e:
        print(f"Error fetching '{endpoint}': {e}", file=sys.stderr)
        return None


def download_submission(submission):
    d = f'submissions/{submission["id"]}'
    Path(d).mkdir(parents=True, exist_ok=True)
    zip_count = 0
    for file_info in submission['files']:
        if file_info['mime'] == 'application/zip':
            print(f"Downloading '{file_info['href']}'")
            try:
                data = dj_utils.do_api_request(file_info['href'], decode=False)
                filename = 'files.zip' if zip_count == 0 else f'files_{zip_count}.zip'
                with open(f'{d}/{filename}', 'wb') as f_handle:
                    f_handle.write(data)
                zip_count += 1
            except Exception as e:
                print(f"Error downloading submission {submission['id']}: {e}", file=sys.stderr)


if len(sys.argv) == 2:
    contest_id = sys.argv[1]
    dj_utils.domjudge_webapp_folder_or_api_url = webappdir
elif len(sys.argv) == 3:
    contest_id = sys.argv[1]
    dj_utils.domjudge_webapp_folder_or_api_url = sys.argv[2]
else:
    usage()


try:
    user_data = dj_utils.do_api_request('user')
    if 'roles' not in user_data or 'admin' not in user_data['roles']:
        print("Your user does not have the 'admin' role, can not export.", file=sys.stderr)
        exit(1)
except Exception as e:
    print(f"Could not verify user roles: {e}", file=sys.stderr)
    exit(1)


submissions = []

for endpoint in [
        'accounts',
        'awards',
        'balloons',
        'clarifications',
        'groups',
        'judgements',
        'languages',
        'organizations',
        'problems',
#        'runs',
        'scoreboard',
        'submissions',
        'teams',
        ]:
    data = api_to_file(f'contests/{contest_id}/{endpoint}', f'{endpoint}.json')
    if endpoint == 'submissions' and data is not None:
        try:
            submissions = json.loads(data)
        except json.JSONDecodeError as e:
            print(f"Error decoding submissions JSON: {e}", file=sys.stderr)

api_to_file(f'contests/{contest_id}/event-feed?stream=false', 'event-feed.ndjson')
api_to_file(f'contests/{contest_id}/results.tsv', 'results.tsv')
api_to_file(f'contests/{contest_id}/scoreboard.zip', 'scoreboard.zip')

if submissions:
    with ThreadPoolExecutor(20) as executor:
        for submission in submissions:
            executor.submit(download_submission, submission)
