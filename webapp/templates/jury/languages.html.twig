{% extends "jury/base.html.twig" %}
{% import "jury/jury_macros.twig" as macros %}

{% block title %}Languages - {{ parent() }}{% endblock %}

{% block extrahead %}
    {{ parent() }}
    {{ macros.table_extrahead() }}
    {{ macros.toggle_extrahead() }}
{% endblock %}

{% block content %}

    <h1>Enabled languages</h1>

    {{ macros.table(enabled_languages, table_fields) }}

    <br/>
    <br/>

    <h1>Disabled languages</h1>

    {{ macros.table(disabled_languages, table_fields) }}

    <p>
        {% if is_granted('ROLE_ADMIN') %}
            {{ button(path('jury_language_add'), 'Add new language', 'primary', 'plus') }}
        {% endif %}
        {{ button(path('jury_versions'), 'Compiler/runner versions', 'outline-secondary', 'server') }}
        {{ button(path('analysis_languages'), 'Language analysis', 'outline-secondary', 'chart-bar') }}
    </p>

{% endblock %}

{% block extrafooter %}
    {{ macros.toggle_autosubmit_extrafooter() }}
{% endblock %}
